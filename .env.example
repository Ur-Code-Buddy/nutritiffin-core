# =============================================================================
# NutriTiffin API — environment template
# =============================================================================
# Copy to `.env` and fill in values. Never commit `.env` or real secrets.
# `PRODUCTION=false` enables dev shortcuts (email/SMS bypass, relaxed throttling).
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Public URL of this API (email verification links, callbacks)
BASE_URL=http://localhost:3000

# Frontend origin (password reset redirects, CORS-related usage)
FRONTEND_URL=http://localhost:5173

# HTTP listen port (see src/main.ts)
PORT=3000

# Production mode: set to `true` for strict OTP, email, and rate limits.
# Omit or set to `false` for local development.
PRODUCTION=false

# Shown on GET /uptime
CURRENT_VERSION=1.0.0

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Option A — single URL (used by TypeORM when set; see src/app.module.ts)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Option B — discrete fields (used when DATABASE_URL is unset)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=
DB_NAME=nutritiffin
# Use `true` for managed providers that require TLS (e.g. Neon, Aiven)
DB_SSL=false

# Optional: some PostgreSQL clients / hosts expect channel binding (rare locally)
# PGCHANNELBINDING=require

# -----------------------------------------------------------------------------
# Authentication & admin
# -----------------------------------------------------------------------------

JWT_SECRET=
# Examples: 1d, 12h, 30m
JWT_EXPIRATION=1d

# Required at startup (src/main.ts). Secret gate for registering ADMIN role.
ADMIN_ACCESS_PASS=

# Optional. Protects POST /resetdb (dangerous — wipes/resets DB). See src/app.controller.ts
SUPER_ADMIN_ACCESS_PASS=

# -----------------------------------------------------------------------------
# AWS S3 (uploads — src/common/s3/s3.service.ts, src/upload/upload.service.ts)
# -----------------------------------------------------------------------------

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET_NAME=

# -----------------------------------------------------------------------------
# Email (Brevo / Sendinblue — transactional mail)
# -----------------------------------------------------------------------------

BREVO_API_KEY=

# -----------------------------------------------------------------------------
# Payments (Razorpay — src/orders/payments.service.ts)
# -----------------------------------------------------------------------------
# RAZORPAY_API_KEY: key id (rzp_test_... / rzp_live_...) — exposed to client as publicKey
# RAZORPAY_KEY_SECRET: server-only; never expose

RAZORPAY_API_KEY=
RAZORPAY_KEY_SECRET=

# -----------------------------------------------------------------------------
# SMS OTP (MessageCentral — src/auth/auth.service.ts)
# -----------------------------------------------------------------------------
# Required when PRODUCTION is not `false` for real OTP send/verify.

SMS_CUSTOMER_ID=
SMS_API_KEY=

# -----------------------------------------------------------------------------
# Redis (health checks, OTP state, BullMQ — src/app.module.ts, src/redis/)
# -----------------------------------------------------------------------------

REDIS_HOST=localhost
REDIS_PORT=6379
# Set `true` for TLS (e.g. ElastiCache in-transit encryption)
REDIS_TLS=false
# Optional password (managed Redis, or src/queue/queue.module.ts if wired)
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Order pricing defaults (rupees / percents — see src/orders/orders.service.ts)
# -----------------------------------------------------------------------------
# PLATFORM_FEES and DELIVERY_FEES: fixed currency amounts per order (defaults below).
# KITCHEN_FEES: treated as a percentage in order calculations (default 15).
# TAX_PERCENT: tax percentage applied in order totals (default 5).

PLATFORM_FEES=10
KITCHEN_FEES=15
DELIVERY_FEES=20
TAX_PERCENT=5

# -----------------------------------------------------------------------------
# Google Maps Platform (live delivery tracking — Routes + Geocoding)
# -----------------------------------------------------------------------------
# Server-only key: enable Routes API and Geocoding API; restrict by server IP.
# Used by src/delivery-tracking/* for ETAs, polylines, and address fallback.

GOOGLE_MAPS_API_KEY=

# -----------------------------------------------------------------------------
# Push notifications (optional)
# -----------------------------------------------------------------------------
# Firebase Admin is initialized from a service account JSON file at the project root:
#   nutritiffinServiceAccountKey.json
# Docker Compose can mount this file; no env vars required for basic FCM setup.
